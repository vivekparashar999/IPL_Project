{
  "version": 2,
  "builds": [
    { "src": "live.html", "use": "@vercel/static" },
    { "src": "api/*.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/matches", "dest": "/api/matches.py" },
    { "src": "/api/match",   "dest": "/api/match.py" },
    { "src": "/",            "dest": "/live.html" },
    { "src": "/live",        "dest": "/live.html" }
  ]
}
